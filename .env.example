CONFLUENCE_OIDC_SCOPES="openid profile email confluence offline_access"
CONFLUENCE_OIDC_USER_CLAIM="sub"

OUTPOSTS_WEB_HOST="outposts.aitiotekt.com"
# OIDC client_id for the frontend web application.
# Used by the backend /api/auth/config projection endpoint to bootstrap the
# browser OIDC flow. No longer baked into the frontend bundle at build time.
OUTPOSTS_WEB_OIDC_CLIENT_ID="to9pyrq4msdo8tv6h8fr9"

AUTH_TYPE="OIDC"

# for oidc type
OIDC_ISSUER="https://auth.aitiotekt.com/oidc"

# for basic type
AUTH_BASIC_USERNAME="outposts"
AUTH_BASIC_PASSWORD="outposts"

NX_NO_CLOUD=true

# Log level for the confluence backend (read by tracing-subscriber EnvFilter).
# Falls back to "info" when unset. Directive syntax: [crate=]level[,...]
# Examples:
#   RUST_LOG=warn                             # production: quiet, only warnings/errors
#   RUST_LOG=info                             # default: general operational logs
#   RUST_LOG=confluence=debug                 # debug confluence only
#   RUST_LOG=confluence=info,sqlx=debug       # info + print all SQL statements
#   RUST_LOG=confluence=trace,tower_http=debug # full trace + HTTP access log
# RUST_LOG=warn
