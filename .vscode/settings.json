{
  "yaml.customTags": [
    "!reset sequence",
    "!override sequence",
    "!reset scalar",
    "!override scalar"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html"
  ],
  "biome.enabled": false
}